<Window x:Class="NarsilNexus.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NarsilNexus.App.ViewModels"
        mc:Ignorable="d"
        Title="NarsilNexus"
        Icon="Assets/AppIcon.ico"
        MinWidth="1080"
        MinHeight="720"
        Width="1180"
        Height="760"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource AppBackgroundBrush}">
    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate x:Key="ToolResultTemplate">
            <Border Style="{DynamicResource ResultRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Status}"
                               Foreground="{Binding StatusBrush}"
                               FontWeight="SemiBold" />
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Name}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Summary}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap" />
                        <Expander Header="Details"
                                  Visibility="{Binding RawOutputVisibility}"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  Margin="0,8,0,0">
                            <TextBox Text="{Binding RawOutput}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     MaxHeight="220"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     Background="{DynamicResource InputBackgroundBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}" />
                        </Expander>
                    </StackPanel>
                    <ProgressBar Grid.Column="2"
                                 Height="6"
                                 IsIndeterminate="{Binding IsRunning}"
                                 Visibility="{Binding RunningVisibility}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WindowChromeBrush}"
                Padding="20,8"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="NarsilNexus"
                               Foreground="{DynamicResource AccentPrimaryBrush}"
                               FontWeight="Bold"
                               FontSize="16" />
                    <TextBlock Text="Network diagnostics workspace"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="10,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Dark"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <CheckBox Style="{DynamicResource ThemeToggleStyle}"
                              IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              ToolTip="Switch theme" />
                    <Button Content="_"
                            Style="{DynamicResource ChromeButtonStyle}"
                            Margin="14,0,4,0"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize" />
                    <Button Content="□"
                            Style="{DynamicResource ChromeButtonStyle}"
                            Margin="0,0,4,0"
                            Click="MaximizeButton_Click"
                            ToolTip="Maximize" />
                    <Button Content="X"
                            Style="{DynamicResource ChromeButtonStyle}"
                            Click="CloseButton_Click"
                            ToolTip="Close" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    Margin="24,18,24,0">
            <TabItem Header="Diagnostics">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{DynamicResource PanelCardStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Saved Target" Style="{DynamicResource FieldLabelStyle}" />
                                <ComboBox SelectedItem="{Binding SelectedTarget}"
                                          ItemsSource="{Binding SavedTargets}"
                                          DisplayMemberPath="DisplayName"
                                          MinHeight="38"
                                          Padding="10,6" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="Target" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding TargetInput, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="12,0,0,0">
                                <TextBlock Text="Target Name" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding TargetName, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="12,0,0,0">
                                <TextBlock Text="DNS Server" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding DnsServerInput, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="12,18,0,0">
                                <Button Content="Save"
                                        Command="{Binding SaveTargetCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}" />
                                <Button Content="Delete"
                                        Command="{Binding DeleteTargetCommand}"
                                        Style="{DynamicResource SecondaryButtonStyle}"
                                        Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{DynamicResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Target Diagnostics"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,14">
                                        <Button Content="Select All"
                                                Command="{Binding SelectAllDiagnosticToolsCommand}"
                                                Style="{DynamicResource SecondaryButtonStyle}" />
                                        <Button Content="Deselect All"
                                                Command="{Binding DeselectAllDiagnosticToolsCommand}"
                                                Style="{DynamicResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0" />
                                    </StackPanel>
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding TargetDiagnosticTools}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding Name}"
                                                          IsChecked="{Binding IsSelected}"
                                                          Margin="0,0,0,10"
                                                          Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Button Grid.Row="2"
                                        Content="{Binding RunButtonText}"
                                        Command="{Binding RunTargetDiagnosticsCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="0,14,0,0" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{DynamicResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Diagnostic Results"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding RunStatusText}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" />
                                    </StackPanel>
                                    <ProgressBar DockPanel.Dock="Right"
                                                 Width="180"
                                                 Height="8"
                                                 IsIndeterminate="{Binding IsRunning}"
                                                 Visibility="{Binding RunningVisibility}" />
                                </DockPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding TargetDiagnosticTools}"
                                                  ItemTemplate="{StaticResource ToolResultTemplate}" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Speed Test">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{DynamicResource PanelCardStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Speed Test"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="0,0,0,14" />

                                <TextBlock Text="Speed Type" Style="{DynamicResource FieldLabelStyle}" />
                                <ComboBox SelectedItem="{Binding SpeedEndpointType}"
                                          ItemsSource="{Binding SpeedEndpointTypes}"
                                          MinHeight="38"
                                          Padding="10,6"
                                          Margin="0,0,0,12" />

                                <TextBlock Text="Saved Endpoint" Style="{DynamicResource FieldLabelStyle}" />
                                <ComboBox SelectedItem="{Binding SelectedSpeedEndpoint}"
                                          ItemsSource="{Binding SavedSpeedEndpoints}"
                                          DisplayMemberPath="DisplayName"
                                          MinHeight="38"
                                          Padding="10,6"
                                          Margin="0,0,0,12" />

                                <TextBlock Text="Speed URL / Base URL" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SpeedResultsApiUrl, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6"
                                         Margin="0,0,0,12" />

                                <TextBlock Text="Endpoint Name" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SpeedEndpointName, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6"
                                         Margin="0,0,0,12" />

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Duration Sec" Style="{DynamicResource FieldLabelStyle}" />
                                        <TextBox Text="{Binding SpeedTestDurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="38"
                                                 Padding="10,6" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ping Samples" Style="{DynamicResource FieldLabelStyle}" />
                                        <TextBox Text="{Binding SpeedPingSamples, UpdateSourceTrigger=PropertyChanged}"
                                                 MinHeight="38"
                                                 Padding="10,6" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="Ping URL" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SpeedProbePingUrl, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6"
                                         Margin="0,0,0,12" />

                                <TextBlock Text="Download URL" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SpeedProbeDownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6"
                                         Margin="0,0,0,12" />

                                <TextBlock Text="Upload URL" Style="{DynamicResource FieldLabelStyle}" />
                                <TextBox Text="{Binding SpeedProbeUploadUrl, UpdateSourceTrigger=PropertyChanged}"
                                         MinHeight="38"
                                         Padding="10,6"
                                         Margin="0,0,0,14" />

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save"
                                            Command="{Binding SaveSpeedEndpointCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}" />
                                    <Button Content="Delete"
                                            Command="{Binding DeleteSpeedEndpointCommand}"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0" />
                                </StackPanel>

                                <Button Content="{Binding RunButtonText}"
                                        Command="{Binding RunSpeedTestCommand}"
                                        Style="{DynamicResource PrimaryButtonStyle}"
                                        Margin="0,16,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Style="{DynamicResource PanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DockPanel Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Speed Result"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding RunStatusText}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="12" />
                                </StackPanel>
                                <ProgressBar DockPanel.Dock="Right"
                                             Width="180"
                                             Height="8"
                                             IsIndeterminate="{Binding IsRunning}"
                                             Visibility="{Binding RunningVisibility}" />
                            </DockPanel>

                            <ContentControl Grid.Row="1"
                                            Content="{Binding SpeedTestTool}"
                                            ContentTemplate="{StaticResource ToolResultTemplate}" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="iperf3">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{DynamicResource PanelCardStyle}">
                        <StackPanel>
                            <TextBlock Text="iperf3"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,14" />
                            <TextBlock Text="Server Host" Style="{DynamicResource FieldLabelStyle}" />
                            <TextBox MinHeight="38"
                                     Padding="10,6"
                                     IsEnabled="False"
                                     Margin="0,0,0,12" />
                            <TextBlock Text="Port" Style="{DynamicResource FieldLabelStyle}" />
                            <TextBox Text="5201"
                                     MinHeight="38"
                                     Padding="10,6"
                                     IsEnabled="False"
                                     Margin="0,0,0,12" />
                            <TextBlock Text="Duration Sec" Style="{DynamicResource FieldLabelStyle}" />
                            <TextBox Text="10"
                                     MinHeight="38"
                                     Padding="10,6"
                                     IsEnabled="False"
                                     Margin="0,0,0,14" />
                            <Button Content="{Binding RunButtonText}"
                                    Command="{Binding RunIperfCommand}"
                                    Style="{DynamicResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{DynamicResource PanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="iperf3 Result"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12" />
                            <ContentControl Grid.Row="1"
                                            Content="{Binding IperfTool}"
                                            ContentTemplate="{StaticResource ToolResultTemplate}" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="History / Reports">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Run History"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Saved diagnostic runs from this device."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="12" />
                        </StackPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Generate Current PDF"
                                Command="{Binding GeneratePdfCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" />
                    </DockPanel>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding HistoryRuns}"
                             SelectedItem="{Binding SelectedHistoryRun}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{DynamicResource ResultRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding OverallStatusText}"
                                                   Foreground="{Binding StatusBrush}"
                                                   FontWeight="SemiBold" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Target}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding SummaryText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding SpeedEndpointText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding HasPdfText}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Load Run"
                                Command="{Binding LoadHistoryRunCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}" />
                        <Button Content="Generate PDF"
                                Command="{Binding GenerateHistoryPdfCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" />
                        <Button Content="Open PDF"
                                Command="{Binding OpenHistoryPdfCommand}"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="24,16,24,18">
            <TextBlock Text="{Binding AppDataPath}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0" />
            <Button Content="Import Config"
                    Command="{Binding ImportConfigCommand}"
                    Style="{DynamicResource SecondaryButtonStyle}" />
            <Button Content="Export Config"
                    Command="{Binding ExportConfigCommand}"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Margin="8,0,0,0" />
            <Button DockPanel.Dock="Right"
                    Content="Open App Data Folder"
                    Command="{Binding OpenAppDataFolderCommand}"
                    Style="{DynamicResource SecondaryButtonStyle}" />
        </DockPanel>
    </Grid>
</Window>
